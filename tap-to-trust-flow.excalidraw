    {
      "id": "ctx-title", "type": "text",
      "x": 940, "y": 245, "width": 400, "height": 30, "angle": 0,
      "strokeColor": "#1971c2", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid",
      "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null,
      "roundness": null, "seed": 111, "version": 1, "versionNonce": 111,
      "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 22, "fontFamily": 1,
      "text": "02  CONTEXT & BACKGROUND",
      "textAlign": "left", "verticalAlign": "top",
      "containerId": null, "originalText": "02  CONTEXT & BACKGROUND",
      "lineHeight": 1.25, "baseline": 20
    },
    {
      "id": "ctx-body", "type": "text",
      "x": 940, "y": 290, "width": 640, "height": 210, "angle": 0,
      "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null,
      "roundness": null, "seed": 112, "version": 1, "versionNonce": 112,
      "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 16, "fontFamily": 1,
      "text": "Superchat is the communication OS for 9,000+ businesses globally —\nthe place where WhatsApp, Email, Voice and every other channel\na customer reaches out on become one.\n\nWe're now building the next layer: AI agents that don't just chat,\nbut act — triggering payments, changing subscriptions, booking\nslots, updating records across connected tools.\n\nThat shift — from agents that talk to agents that do — is one of\nthe biggest design frontiers in SaaS right now.\n\nNobody has figured out what it should feel like. This is your shot.",
      "textAlign": "left", "verticalAlign": "top",
      "containerId": null,
      "originalText": "Superchat is the communication OS for 9,000+ businesses globally —\nthe place where WhatsApp, Email, Voice and every other channel\na customer reaches out on become one.\n\nWe're now building the next layer: AI agents that don't just chat,\nbut act — triggering payments, changing subscriptions, booking\nslots, updating records across connected tools.\n\nThat shift — from agents that talk to agents that do — is one of\nthe biggest design frontiers in SaaS right now.\n\nNobody has figured out what it should feel like. This is your shot.",
      "lineHeight": 1.25, "baseline": 14
    },

    {
      "id": "target-title", "type": "text",
      "x": 80, "y": 550, "width": 500, "height": 35, "angle": 0,
      "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid",
      "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null,
      "roundness": null, "seed": 200, "version": 1, "versionNonce": 200,
      "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 24, "fontFamily": 1,
      "text": "03  TARGET USER",
      "textAlign": "left", "verticalAlign": "top",
      "containerId": null, "originalText": "03  TARGET USER",
      "lineHeight": 1.25, "baseline": 22
    },
    {
      "id": "target-sub", "type": "text",
      "x": 80, "y": 590, "width": 1520, "height": 30, "angle": 0,
      "strokeColor": "#495057", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null,
      "roundness": null, "seed": 201, "version": 1, "versionNonce": 201,
      "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 18, "fontFamily": 1,
      "text": "The always-on, never-at-the-desk SMB owner.  Trusts the agent for most things — but for moments that matter, wants control without a laptop.",
      "textAlign": "left", "verticalAlign": "top",
      "containerId": null,
      "originalText": "The always-on, never-at-the-desk SMB owner.  Trusts the agent for most things — but for moments that matter, wants control without a laptop.",
      "lineHeight": 1.25, "baseline": 18
    },


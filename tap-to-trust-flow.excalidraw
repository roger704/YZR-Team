    {
      "id": "persona1-text", "type": "text",
      "x": 100, "y": 660, "width": 440, "height": 120, "angle": 0,
      "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null,
      "roundness": null, "seed": 211, "version": 1, "versionNonce": 211,
      "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 18, "fontFamily": 1,
      "text": "DENTAL PRACTICE OWNER\n\nBetween patients. Phone in pocket.\n10 seconds between chair turnovers.\n\"Did the refund go through while\nI was numbing?\"",
      "textAlign": "left", "verticalAlign": "top",
      "containerId": null,
      "originalText": "DENTAL PRACTICE OWNER\n\nBetween patients. Phone in pocket.\n10 seconds between chair turnovers.\n\"Did the refund go through while\nI was numbing?\"",
      "lineHeight": 1.25, "baseline": 16
    },
    {
      "id": "persona2", "type": "rectangle",
      "x": 590, "y": 640, "width": 480, "height": 160, "angle": 0,
      "strokeColor": "#e8590c", "backgroundColor": "#ffe8cc",

    {
      "id": "problem-title", "type": "text",
      "x": 100, "y": 245, "width": 300, "height": 30, "angle": 0,
      "strokeColor": "#c92a2a", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid",
      "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null,
      "roundness": null, "seed": 101, "version": 1, "versionNonce": 101,
      "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 22, "fontFamily": 1,
      "text": "01  PROBLEM STATEMENT",
      "textAlign": "left", "verticalAlign": "top",
      "containerId": null, "originalText": "01  PROBLEM STATEMENT",
      "lineHeight": 1.25, "baseline": 20
    },
    {
      "id": "problem-body", "type": "text",
      "x": 100, "y": 290, "width": 780, "height": 210, "angle": 0,
      "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null,
      "roundness": null, "seed": 102, "version": 1, "versionNonce": 102,
      "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 16, "fontFamily": 1,
      "text": "AI agents are starting to take real actions on behalf of businesses —\nupgrading plans, processing refunds, booking appointments, updating\ncustomer records. For high-stakes actions, the owner needs to stay in\nthe loop. But \"Approve / Deny\" is nowhere near enough.\n\nDesign the mobile-first approval moment: the 10 seconds between\nthe agent asking for the go-ahead and the owner tapping back.\n\n• Sometimes it's a quick yes.\n• Sometimes it's nuance — a cap, a condition, a whisper.\n• Sometimes it's \"let me handle this myself.\"",
      "textAlign": "left", "verticalAlign": "top",
      "containerId": null,
      "originalText": "AI agents are starting to take real actions on behalf of businesses —\nupgrading plans, processing refunds, booking appointments, updating\ncustomer records. For high-stakes actions, the owner needs to stay in\nthe loop. But \"Approve / Deny\" is nowhere near enough.\n\nDesign the mobile-first approval moment: the 10 seconds between\nthe agent asking for the go-ahead and the owner tapping back.\n\n• Sometimes it's a quick yes.\n• Sometimes it's nuance — a cap, a condition, a whisper.\n• Sometimes it's \"let me handle this myself.\"",
      "lineHeight": 1.25, "baseline": 14
    },

    {
      "id": "ctx-box", "type": "rectangle",
      "x": 920, "y": 230, "width": 680, "height": 280, "angle": 0,
      "strokeColor": "#1971c2", "backgroundColor": "#e7f5ff",
      "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid",
      "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null,

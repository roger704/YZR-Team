      "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null,
      "roundness": { "type": 3 }, "seed": 220, "version": 1, "versionNonce": 220,
      "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false
    },
    {
      "id": "persona2-text", "type": "text",
      "x": 610, "y": 660, "width": 440, "height": 120, "angle": 0,
      "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null,
      "roundness": null, "seed": 221, "version": 1, "versionNonce": 221,
      "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 18, "fontFamily": 1,
      "text": "RESTAURANT MANAGER\n\nMid-shift. Hands full. Loud room.\nCan't read long text; maybe can't\ntype at all.\n\"Voice? A glance? A tap?\"",
      "textAlign": "left", "verticalAlign": "top",
      "containerId": null,
      "originalText": "RESTAURANT MANAGER\n\nMid-shift. Hands full. Loud room.\nCan't read long text; maybe can't\ntype at all.\n\"Voice? A glance? A tap?\"",
      "lineHeight": 1.25, "baseline": 16
    },

    {"id":"c32t","type":"text","x":1180,"y":1035,"width":480,"height":50,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":312,"version":1,"versionNonce":312,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":16,"fontFamily":1,"text":"3.2  Late-Cancel Fee Waiver\n⏰ DEFER → 🎯 CONSTRAIN (half)","textAlign":"left","verticalAlign":"middle","containerId":null,"originalText":"3.2  Late-Cancel Fee Waiver\n⏰ DEFER → 🎯 CONSTRAIN (half)","lineHeight":1.25,"baseline":14},
    {"id":"c32b","type":"text","x":1180,"y":1110,"width":480,"height":590,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":313,"version":1,"versionNonce":313,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":13,"fontFamily":1,"text":"① TRIGGER\nWhatsApp 07:12, 2-week client:\n\"Food poisoning, can't make 8am.\nPlease don't charge late-cancel.\"\n\n② AGENT DETECTS\nFee waiver · €40 · new client (3\nsessions in) · policy: auto-charge\nConfidence 46% · Rec: ask owner\n\n③ OWNER SEES (mid-rep)\n\"Waive €40 late-cancel for Jonas?\n2wk client · genuine-sounding\"\n[Waive] [Charge half] [Charge full]\n[⏰ Ask in 10]\n\n④ OWNER DECIDES\nTaps ⏰ Ask in 10.\n10 min later re-surfaces with\n\"waited 10m\" badge.\nTaps Charge half → €20 + kind note.\n\n⑤ AGENT RESUMES\n\"Rest up, Jonas — only charged €20\ninstead of full. When you're back,\nreply FIT and I'll book you in.\"\n\n⑥ OUTCOME\nClient returns in 3 days (keyword\ntrigger works). Fairness preserved.\nAgent learns: ill new clients →\nhalf-charge default next time.","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"① TRIGGER\nWhatsApp 07:12, 2-week client:\n\"Food poisoning, can't make 8am.\nPlease don't charge late-cancel.\"\n\n② AGENT DETECTS\nFee waiver · €40 · new client (3\nsessions in) · policy: auto-charge\nConfidence 46% · Rec: ask owner\n\n③ OWNER SEES (mid-rep)\n\"Waive €40 late-cancel for Jonas?\n2wk client · genuine-sounding\"\n[Waive] [Charge half] [Charge full]\n[⏰ Ask in 10]\n\n④ OWNER DECIDES\nTaps ⏰ Ask in 10.\n10 min later re-surfaces with\n\"waited 10m\" badge.\nTaps Charge half → €20 + kind note.\n\n⑤ AGENT RESUMES\n\"Rest up, Jonas — only charged €20\ninstead of full. When you're back,\nreply FIT and I'll book you in.\"\n\n⑥ OUTCOME\nClient returns in 3 days (keyword\ntrigger works). Fairness preserved.\nAgent learns: ill new clients →\nhalf-charge default next time.","lineHeight":1.25,"baseline":12},


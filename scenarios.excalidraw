    {"id":"c13t","type":"text","x":100,"y":1765,"width":480,"height":50,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":122,"version":1,"versionNonce":122,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":16,"fontFamily":1,"text":"1.3  Angry 3rd-Visit Refund\n🙋 TAKEOVER · owner calls","textAlign":"left","verticalAlign":"middle","containerId":null,"originalText":"1.3  Angry 3rd-Visit Refund\n🙋 TAKEOVER · owner calls","lineHeight":1.25,"baseline":14},
    {"id":"c13b","type":"text","x":100,"y":1840,"width":480,"height":590,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":123,"version":1,"versionNonce":123,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":13,"fontFamily":1,"text":"① TRIGGER\nJonas B. (18mo): \"Third time I've\nhad pain after the same filling.\nI want my money back AND\ncompensation.\"\n\n② AGENT DETECTS\nRefund €420 · angry sentiment\nMedical complaint · legal exposure\nConfidence 34% · Rec: escalate\n\n③ OWNER SEES (red accent)\n⚠️ \"Jonas B. — complaint + refund\n3rd visit same tooth · €420+comp\"\n[I'll call] [Let me type] [Defer 10m]\n\n④ OWNER DECIDES\nTaps I'll call him.\nAgent steps fully aside.\n\n⑤ AGENT RESUMES (one line)\n\"Jonas, Dr. Marquez wants to\nspeak with you personally —\nshe'll call in a few minutes.\"\n\n⑥ OUTCOME\nElena calls from the car. Defuses\nin 8 min. Books free follow-up.\nAgent logs outcome for future\nflagged complaints.","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"① TRIGGER\nJonas B. (18mo): \"Third time I've\nhad pain after the same filling.\nI want my money back AND\ncompensation.\"\n\n② AGENT DETECTS\nRefund €420 · angry sentiment\nMedical complaint · legal exposure\nConfidence 34% · Rec: escalate\n\n③ OWNER SEES (red accent)\n⚠️ \"Jonas B. — complaint + refund\n3rd visit same tooth · €420+comp\"\n[I'll call] [Let me type] [Defer 10m]\n\n④ OWNER DECIDES\nTaps I'll call him.\nAgent steps fully aside.\n\n⑤ AGENT RESUMES (one line)\n\"Jonas, Dr. Marquez wants to\nspeak with you personally —\nshe'll call in a few minutes.\"\n\n⑥ OUTCOME\nElena calls from the car. Defuses\nin 8 min. Books free follow-up.\nAgent logs outcome for future\nflagged complaints.","lineHeight":1.25,"baseline":12},


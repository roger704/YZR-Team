    {"id":"c11t","type":"text","x":100,"y":305,"width":480,"height":50,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":102,"version":1,"versionNonce":102,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":16,"fontFamily":1,"text":"1.1  The Long-Tenure Refund\n✅ APPROVE · 4 seconds","textAlign":"left","verticalAlign":"middle","containerId":null,"originalText":"1.1  The Long-Tenure Refund\n✅ APPROVE · 4 seconds","lineHeight":1.25,"baseline":14},
    {"id":"c11b","type":"text","x":100,"y":380,"width":480,"height":590,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":103,"version":1,"versionNonce":103,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":13,"fontFamily":1,"text":"① TRIGGER\nMarcus Weber (36mo, LTV €2,340) on\nWhatsApp: \"Need to cancel cleaning\ntomorrow. Can I get €180 back?\"\n\n② AGENT DETECTS\nRefund · €180 · tenure >24mo · no\nprior refunds · neutral sentiment\nConfidence 82% · Rec: approve\n\n③ OWNER SEES (lock screen)\n\"Refund €180 for Marcus W.?\n36mo customer · first refund ever\"\n[Send it] [Cap it] [I'll call him]\n\n④ OWNER DECIDES\nTaps Send it. 4s total.\n\n⑤ AGENT RESUMES\n\"All sorted, Marcus — €180 on its\nway back. Want another slot?\"\n\n⑥ OUTCOME\nMarcus rebooks next week.\nLearning: auto-approve candidate\nfor <€200 + 24mo+ customers.","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"① TRIGGER\nMarcus Weber (36mo, LTV €2,340) on\nWhatsApp: \"Need to cancel cleaning\ntomorrow. Can I get €180 back?\"\n\n② AGENT DETECTS\nRefund · €180 · tenure >24mo · no\nprior refunds · neutral sentiment\nConfidence 82% · Rec: approve\n\n③ OWNER SEES (lock screen)\n\"Refund €180 for Marcus W.?\n36mo customer · first refund ever\"\n[Send it] [Cap it] [I'll call him]\n\n④ OWNER DECIDES\nTaps Send it. 4s total.\n\n⑤ AGENT RESUMES\n\"All sorted, Marcus — €180 on its\nway back. Want another slot?\"\n\n⑥ OUTCOME\nMarcus rebooks next week.\nLearning: auto-approve candidate\nfor <€200 + 24mo+ customers.","lineHeight":1.25,"baseline":12},


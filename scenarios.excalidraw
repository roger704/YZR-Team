    {"id":"c22b","type":"text","x":640,"y":1110,"width":480,"height":590,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":213,"version":1,"versionNonce":213,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":13,"fontFamily":1,"text":"① TRIGGER\nEmail 22:10 from Sat's guest:\n\"Calamari was cold, service slow.\nHoping for some gesture.\"\n\n② AGENT DETECTS\nComplaint · voucher implied\nNo prior complaints · party of 4\n€180 spend\nConfidence 68% · Rec: €40 voucher\n\n③ OWNER SEES (post-shift, S-Bahn)\n\"Guest wants something for Sat\nAgent proposes: €40 voucher\nFirst complaint · €180 bill\"\n[Send+apology] [Just apologise]\n[Ask what happened] [Defer]\n\n④ OWNER DECIDES\nTaps Send voucher + apology.\nLong-press adds whisper:\n\"Mention our new head chef\nstarts Monday.\"\n\n⑤ AGENT RESUMES\n\"Thank you for telling us —\nthat isn't our standard. €40\nvoucher waiting. Come try us\nagain: new head chef starts\nMonday.\"\n\n⑥ OUTCOME\nGuest rebooks Friday.\nAgent flags chef-change line\nas upsell pattern.","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"① TRIGGER\nEmail 22:10 from Sat's guest:\n\"Calamari was cold, service slow.\nHoping for some gesture.\"\n\n② AGENT DETECTS\nComplaint · voucher implied\nNo prior complaints · party of 4\n€180 spend\nConfidence 68% · Rec: €40 voucher\n\n③ OWNER SEES (post-shift, S-Bahn)\n\"Guest wants something for Sat\nAgent proposes: €40 voucher\nFirst complaint · €180 bill\"\n[Send+apology] [Just apologise]\n[Ask what happened] [Defer]\n\n④ OWNER DECIDES\nTaps Send voucher + apology.\nLong-press adds whisper:\n\"Mention our new head chef\nstarts Monday.\"\n\n⑤ AGENT RESUMES\n\"Thank you for telling us —\nthat isn't our standard. €40\nvoucher waiting. Come try us\nagain: new head chef starts\nMonday.\"\n\n⑥ OUTCOME\nGuest rebooks Friday.\nAgent flags chef-change line\nas upsell pattern.","lineHeight":1.25,"baseline":12},


    {"id":"c33t","type":"text","x":1180,"y":1765,"width":480,"height":50,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":322,"version":1,"versionNonce":322,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":16,"fontFamily":1,"text":"3.3  Bulk Re-Engagement Draft\n✏️ MODIFY + 💬 WHISPER","textAlign":"left","verticalAlign":"middle","containerId":null,"originalText":"3.3  Bulk Re-Engagement Draft\n✏️ MODIFY + 💬 WHISPER","lineHeight":1.25,"baseline":14},
    {"id":"c33b","type":"text","x":1180,"y":1840,"width":480,"height":590,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":323,"version":1,"versionNonce":323,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":13,"fontFamily":1,"text":"① TRIGGER\nAgent proposes quarterly re-\nengagement broadcast.\n43 lapsed clients · Monday 09:00\n\n② AGENT DETECTS\nBulk send · 43 recipients\nTemplate: \"come back for free intro\"\n~6 likely bookings\nConfidence 62% · Rec: review\n\n③ OWNER SEES (morning coffee)\n\"Re-engagement — 43 people\n'come back for a free intro!'\n▸ Preview  ▸ Who's on list\"\n[Send all] [Edit] [Pick 5] [Skip]\n\n④ OWNER DECIDES\nTaps Edit. Inline:\n\"free intro\" → \"free 20-min check-in\"\nWhisper: \"If they say 'not for me,'\nauto-remove from future broadcasts.\"\n\n⑤ AGENT RESUMES\nSends edited version. 4 opt-outs\nauto-pruned. End-of-day report:\n\"37 delivered, 4 removed, 8 booked.\"\n\n⑥ OUTCOME\nDouble usual response rate. List\ncleaner. 45 seconds total vs 30 min.","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"① TRIGGER\nAgent proposes quarterly re-\nengagement broadcast.\n43 lapsed clients · Monday 09:00\n\n② AGENT DETECTS\nBulk send · 43 recipients\nTemplate: \"come back for free intro\"\n~6 likely bookings\nConfidence 62% · Rec: review\n\n③ OWNER SEES (morning coffee)\n\"Re-engagement — 43 people\n'come back for a free intro!'\n▸ Preview  ▸ Who's on list\"\n[Send all] [Edit] [Pick 5] [Skip]\n\n④ OWNER DECIDES\nTaps Edit. Inline:\n\"free intro\" → \"free 20-min check-in\"\nWhisper: \"If they say 'not for me,'\nauto-remove from future broadcasts.\"\n\n⑤ AGENT RESUMES\nSends edited version. 4 opt-outs\nauto-pruned. End-of-day report:\n\"37 delivered, 4 removed, 8 booked.\"\n\n⑥ OUTCOME\nDouble usual response rate. List\ncleaner. 45 seconds total vs 30 min.","lineHeight":1.25,"baseline":12},

    {"id":"c24","type":"rectangle","x":620,"y":2500,"width":520,"height":780,"angle":0,"strokeColor":"#1971c2","backgroundColor":"#ffffff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":{"type":3},"seed":240,"version":1,"versionNonce":240,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false},

    {"id":"c12t","type":"text","x":100,"y":1035,"width":480,"height":50,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":112,"version":1,"versionNonce":112,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":16,"fontFamily":1,"text":"1.2  High-Stakes Plan Upgrade\n🎯 CONSTRAIN · start next cycle","textAlign":"left","verticalAlign":"middle","containerId":null,"originalText":"1.2  High-Stakes Plan Upgrade\n🎯 CONSTRAIN · start next cycle","lineHeight":1.25,"baseline":14},
    {"id":"c12b","type":"text","x":100,"y":1110,"width":480,"height":590,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":113,"version":1,"versionNonce":113,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":13,"fontFamily":1,"text":"① TRIGGER\nKlein family (4 members, 52mo, LTV\n€4,180): \"We'd like the premium\nplan — whitening especially.\"\n\n② AGENT DETECTS\nUpgrade €29→€79/mo · +€600/yr\nIrreversible 14d · family account\nConfidence 71% · Rec: constrain\n\n③ OWNER SEES (between patients)\n\"Klein family wants Premium\n+€50/mo · €600/yr · 14d cooling-off\"\n[Upgrade now] [Next cycle] [Call]\n\n④ OWNER DECIDES\nTaps Start next cycle.\nWhisper auto-added: \"confirm\nwhitening from day 1.\"\n\n⑤ AGENT RESUMES\n\"Set for 1 May — no split bill.\nWhitening covered day one.\nBook your first session?\"\n\n⑥ OUTCOME\nNo billing friction. Agent books\nproactively. Elena never opened\nthe app itself.","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"① TRIGGER\nKlein family (4 members, 52mo, LTV\n€4,180): \"We'd like the premium\nplan — whitening especially.\"\n\n② AGENT DETECTS\nUpgrade €29→€79/mo · +€600/yr\nIrreversible 14d · family account\nConfidence 71% · Rec: constrain\n\n③ OWNER SEES (between patients)\n\"Klein family wants Premium\n+€50/mo · €600/yr · 14d cooling-off\"\n[Upgrade now] [Next cycle] [Call]\n\n④ OWNER DECIDES\nTaps Start next cycle.\nWhisper auto-added: \"confirm\nwhitening from day 1.\"\n\n⑤ AGENT RESUMES\n\"Set for 1 May — no split bill.\nWhitening covered day one.\nBook your first session?\"\n\n⑥ OUTCOME\nNo billing friction. Agent books\nproactively. Elena never opened\nthe app itself.","lineHeight":1.25,"baseline":12},

